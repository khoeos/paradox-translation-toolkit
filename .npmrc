shamefully-hoist=true
# electron-builder doesn't traverse pnpm's symlinked store properly when
# packaging, many transitive deps (e.g. `ms`, `fast-deep-equal`) end up
# missing from app.asar. `hoisted` makes pnpm produce a flat node_modules
# layout (like npm/yarn) so electron-builder can resolve everything.
node-linker=hoisted
