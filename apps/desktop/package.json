{
  "name": "@ptt/desktop",
  "productName": "Paradox Translation Toolkit",
  "version": "3.0.0-beta.1",
  "type": "module",
  "private": true,
  "license": "CC BY-NC-SA 4.0",
  "description": "Help players and modders from many Paradox games to manage language and localisation files within mods",
  "author": "Khoeos",
  "homepage": "https://github.com/khoeos/paradox-translation-toolkit",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev -w",
    "build": "electron-vite build",
    "_deploy:prod": "rimraf dist-deploy && pnpm --filter=@ptt/desktop deploy --prod --legacy ./dist-deploy",
    "build:win": "pnpm run build && pnpm run _deploy:prod && pnpm --dir=./dist-deploy exec electron-builder --win",
    "build:linux": "pnpm run build && pnpm run _deploy:prod && pnpm --dir=./dist-deploy exec electron-builder --linux",
    "build:mac": "pnpm run build && pnpm run _deploy:prod && pnpm --dir=./dist-deploy exec electron-builder --mac",
    "build:unpack": "pnpm run build && pnpm run _deploy:prod && pnpm --dir=./dist-deploy exec electron-builder --dir",
    "release": "pnpm run build && pnpm run _deploy:prod && pnpm --dir=./dist-deploy exec electron-builder --publish always",
    "lint": "oxlint src",
    "typecheck": "tsc --noEmit -p tsconfig.web.json && tsc --noEmit -p tsconfig.node.json",
    "test": "vitest run --passWithNoTests",
    "clean": "rimraf dist dist-deploy out .turbo"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@ptt/converter-core": "workspace:*",
    "@ptt/game-registry": "workspace:*",
    "@ptt/i18n": "workspace:*",
    "@ptt/parser-core": "workspace:*",
    "@ptt/shared-types": "workspace:*",
    "@ptt/ui": "workspace:*",
    "@tanstack/react-query": "^5.100.6",
    "@tanstack/react-router": "^1.168.25",
    "@tanstack/react-virtual": "^3.13.5",
    "@trpc/client": "^11.17.0",
    "@trpc/react-query": "^11.17.0",
    "@trpc/server": "^11.17.0",
    "electron-log": "^5.4.3",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.8.3",
    "electron-window-state": "^5.0.3",
    "i18next": "catalog:",
    "lucide-react": "^1.14.0",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-i18next": "^17.0.6",
    "zod": "catalog:",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.4",
    "@tailwindcss/vite": "^4.2.4",
    "@tanstack/react-query-devtools": "^5.100.6",
    "@tanstack/react-router-devtools": "^1.166.13",
    "@tanstack/router-plugin": "^1.167.28",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.0.4",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "postcss": "^8.5.12",
    "rimraf": "catalog:",
    "tailwindcss": "^4.2.4",
    "typescript": "catalog:",
    "vite": "^7.1.0",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "catalog:"
  }
}
